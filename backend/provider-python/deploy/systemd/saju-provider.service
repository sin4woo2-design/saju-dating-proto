[Unit]
Description=Saju Python Provider (FastAPI)
After=network.target

[Service]
Type=simple
User=sin4woo2
WorkingDirectory=/home/sin4woo2/saju-dating-proto/backend/provider-python
EnvironmentFile=/home/sin4woo2/saju-dating-proto/backend/provider-python/deploy/env/provider.env
ExecStart=/home/sin4woo2/saju-dating-proto/backend/provider-python/scripts/run-provider.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
